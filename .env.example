# Rating weights for automated rating (values between 0 and 1). Sum ideally 1.0
# RATING_WEIGHT_COMPLETION: weight for task completion rate (default 0.6)
# RATING_WEIGHT_TIMELINESS: weight for timeliness (default 0.3)
# RATING_WEIGHT_PROFICIENCY: weight for skill proficiency (default 0.1)
RATING_WEIGHT_COMPLETION=0.6
RATING_WEIGHT_TIMELINESS=0.3
RATING_WEIGHT_PROFICIENCY=0.1
